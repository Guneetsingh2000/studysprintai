generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id          Int          @id @default(autoincrement())
  fullName    String
  email       String       @unique
  program     String
  courses     Course[]
  assignments Assignment[]
  studyPlans  StudyPlan[]
  reminders   Reminder[]
}

model Course {
  id         Int     @id @default(autoincrement())
  courseCode String
  courseName String
  instructor String
  studentId  Int
  student    Student @relation(fields: [studentId], references: [id])

  // Implicit back-relation required by Prisma for Assignment.course field
  assignments Assignment[]
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  dueDate   DateTime
  status    String
  priority  String
  courseId  Int
  studentId Int
  course    Course   @relation(fields: [courseId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])
}

model StudyPlan {
  id        Int      @id @default(autoincrement())
  topic     String
  studyDate DateTime
  duration  Int
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
}

model Reminder {
  id           Int      @id @default(autoincrement())
  message      String
  reminderDate DateTime
  type         String
  studentId    Int
  student      Student  @relation(fields: [studentId], references: [id])
}
