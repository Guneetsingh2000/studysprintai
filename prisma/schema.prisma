generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id          Int          @id @default(autoincrement())
  fullName    String
  email       String       @unique
  program     String
  courses     Course[]
  assignments Assignment[]
  studyPlans  StudyPlan[]
  reminders   Reminder[]
}

model Course {
  id         Int     @id @default(autoincrement())
  courseCode String
  courseName String
  instructor String
  studentId  Int
  student    Student @relation(fields: [studentId], references: [id])

  // Implicit back-relation required by Prisma for Assignment.course field
  assignments Assignment[]
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  dueDate   DateTime
  status    String
  priority  String
  courseId  Int
  studentId Int
  course    Course   @relation(fields: [courseId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])
}

model StudyPlan {
  id        Int      @id @default(autoincrement())
  topic     String
  studyDate DateTime
  duration  Int
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
}

model Reminder {
  id           Int      @id @default(autoincrement())
  message      String
  reminderDate DateTime
  type         String
  studentId    Int
  student      Student  @relation(fields: [studentId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  firstName     String?
  lastName      String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  role          String    @default("STUDENT")
  isVerified    Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
